---
/**
 * PhotoGallery.astro
 *
 * A PhotoSwipe-powered lightbox gallery for blog posts.
 *
 * Usage in an .mdx post:
 *
 *   import PhotoGallery from "@/components/blog/PhotoGallery.astro";
 *   export const images = import.meta.glob("./*.{jpg,jpeg,png,gif,webp}", { eager: true });
 *
 *   <PhotoGallery images={images} />
 *
 * The `images` prop is the result of import.meta.glob with eager:true,
 * which Astro resolves at build time — giving us the optimized image
 * objects (with src, width, height) needed for PhotoSwipe.
 */

import { getImage } from "astro:assets";

interface ImageModule {
	default: ImageMetadata;
}

interface Props {
	images: Record<string, ImageModule>;
}

const { images } = Astro.props;

// Sort by filename so the order is predictable
const sorted = Object.entries(images).sort(([a], [b]) => a.localeCompare(b));

// For each image, generate:
//   - a thumbnail (optimized, max 600px wide) for the grid
//   - the full-size URL + dimensions for PhotoSwipe
const items = await Promise.all(
	sorted.map(async ([, mod]) => {
		const src = mod.default;

		const thumb = await getImage({
			src,
			width: 600,
			format: "webp",
			quality: 80,
		});

		const full = await getImage({
			src,
			width: src.width,
			height: src.height,
			format: "webp",
			quality: 90,
		});

		return {
			thumbSrc: thumb.src,
			fullSrc: full.src,
			width: src.width,
			height: src.height,
			alt: src.src.split("/").pop()?.replace(/\.[^.]+$/, "") ?? "",
		};
	}),
);
---

<div class="pswp-gallery my-8 grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-4" id="photo-gallery">
	{
		items.map((item) => (
			<a
				href={item.fullSrc}
				data-pswp-width={item.width}
				data-pswp-height={item.height}
				target="_blank"
				rel="noreferrer"
			>
				<img
					src={item.thumbSrc}
					alt={item.alt}
					loading="lazy"
					decoding="async"
					class="aspect-square w-full rounded object-cover transition-opacity hover:opacity-90"
				/>
			</a>
		))
	}
</div>

<script>
	import PhotoSwipeLightbox from "photoswipe/lightbox";
	import "photoswipe/style.css";

	const lightbox = new PhotoSwipeLightbox({
		gallery: "#photo-gallery",
		children: "a",
		pswpModule: () => import("photoswipe"),
		// Smooth open/close animation
		showHideAnimationType: "zoom",
		// Don't close when clicking the backdrop
		clickToCloseNonZoomable: false,
	});

	lightbox.init();
</script>
